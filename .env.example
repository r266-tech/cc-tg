# ── Required ───────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
ALLOWED_USER_ID=your_telegram_user_id   # 必填; 留空 = 全 deny (安全默认)
CLAUDE_CLI_PATH=/path/to/claude
ANTHROPIC_API_KEY=                       # 默认隔离模式必填; 共享模式留空

# ── Isolation switches (容器化 / 多 babata 共存核心) ───────────────────
# babata 默认是 "纯净容器": 不读用户 ~/.claude/, cwd 限定 repo 自身, 重要 tool
# call 提示授权. 对开源用户 = 装上不污染日常 CC, 不会 access 用户家目录.

# 共享用户 ~/.claude/ (skill / settings.json / OAuth keychain). 1=共享, 空=隔离.
# 共享模式不需要 ANTHROPIC_API_KEY (走 OAuth), 但 babata 跑的任务算入用户 CC quota.
# BABATA_SHARED_CC=1

# 完全信任 — cwd=$HOME + permission_mode=auto (CC 官方 auto mode, status 显示
# "auto mode on"). 让 babata 能 access 整个家目录, 低风险 tool call 不弹授权.
# ⚠️ 风险大: 任何能给 bot 发消息的人都能让 babata 读你家任何文件 / 跑任何命令.
# 只在 ALLOWED_USER_ID 严格设好时打开.
# BABATA_FULL_TRUST=1

# ── Multi-instance (单机跑多个 babata) ──────────────────────────────────
# 实例命名: 默认 main bot 名为 PROJECT_NAMESPACE (默认 "babata"). 多 instance 走
# BABATA_INSTANCE 区分 (e.g. BABATA_INSTANCE=alice → 第二个 bot 跟 main 共享代码,
# 独立 state / socket / launchd label / TG token).
# PROJECT_NAMESPACE=babata
# BABATA_INSTANCE=

# /resume 渠道 picker 显示名 (中文 / 英文 / 自定义都行)
# BABATA_LABEL_MAIN=babata
# BABATA_LABEL_weixin=wx

# ── Optional paths ─────────────────────────────────────────────────────
# state 目录 — 默认 repo-local (容器化), 改这里把 state 放别处
# PROJECT_STATE_DIR=

# skill-evolve hooks 目录 — 默认空 (不 fire). 设路径让 cc.py 启动 / 切 session 时
# 跑 session-{start,end}.sh. 用户自己的 skill-evolve 系统才需要.
# PROJECT_SKILL_HOOKS_DIR=

# /provider 命令依赖外部 cc-router 服务 — 默认空 = /provider 显示 "未配置".
# BABATA_CC_ROUTER_DIR=

# ── Voice (TTS + STT) — 默认本地免费, 填 MIMO env 升级 ─────────────────
# 默认 (留空): TTS = MS Edge 免费 (zh-CN-XiaoxiaoNeural); STT = faster-whisper 本地
# (base 模型 ~150MB 首跑自动下载到 ~/.cache/). 不需要 API key.

# 可选: 切自定义 TTS endpoint (mimo / openai 兼容). 留空走免费 edge-tts.
# TTS_BACKEND: "openai" (POST /audio/speech) | "mimo" (POST /chat/completions)
TTS_URL=
TTS_BACKEND=openai
TTS_MODEL=tts-1
TTS_VOICE=nova
TTS_API_KEY=

# 可选: 升级 STT 到 MiMo Omni (中文识别更准, 视频理解一并启用).
# 不填 → 走本地 faster-whisper. 填了 → 走 MiMo. 视频功能必须填.
# Example: MIMO_API_URL=https://api.xiaomimimo.com/v1
MIMO_API_URL=
MIMO_API_KEY=

# 本地 STT 模型大小 (faster-whisper). 越大越准但越慢 + 越占空间:
#   tiny (75MB / 中文一般) | base (150MB, 默认 / 中文凑合) |
#   small (500MB / 中文好) | medium (1.5GB / 中文优秀) | large-v3 (3GB / 最准)
# STT_LOCAL_MODEL=base

# Per-task model (MiMo 路径; 默认 mimo-v2.5 — v2.5 含多模态, v2.5-pro 是纯文本):
# STT_MODEL=mimo-v2.5
# VIDEO_MODEL=mimo-v2.5

# Optional STT prompt override (MiMo 路径生效):
# STT_PROMPT=转录这段语音, 只输出文本, 不要解释。

# Optional: map button attached to tg_send_location. "amap"|"google"|"osm"|"none"
MAP_PROVIDER=amap
